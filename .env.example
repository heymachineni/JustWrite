# Firebase (client)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=

# Firebase Admin (server) — use ONE of these in Vercel:
FIREBASE_SERVICE_ACCOUNT_JSON=
# Or base64 of the same JSON (safer on Vercel — run scripts/print-vercel-env.mjs)
FIREBASE_SERVICE_ACCOUNT_JSON_BASE64=

# Email OTP delivery (optional in dev — code logs to server console)
RESEND_API_KEY=
AUTH_EMAIL_FROM=Just Write <onboarding@resend.dev>
